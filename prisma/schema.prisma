// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  password      String
  name          String?
  role          String    @default("employee") // "employee" lub "leader"
  leaderId      Int?      @map("leader_id") // ID lidera przypisanego do pracownika
  daysAvailable Int       @default(26) // Dostępne dni urlopu
  daysPerYear   Int       @default(26) // Ile dni dodaje się po przekroczeniu roku
  createdAt     String    @default("CURRENT_TIMESTAMP") @map("created_at")
  mustChangePassword Boolean @default(false) @map("must_change_password")
  cancelledLeaveRequests LeaveRequest[] @relation("LeaveRequestCancelledBy")
  editedLeaveRequests    LeaveRequest[] @relation("LeaveRequestEditedBy")
  acceptedLeaveRequests  LeaveRequest[] @relation("LeaveRequestAcceptedBy")

  @@map("users")
}

model LeaveRequest {
  id                    Int       @id @default(autoincrement())
  employeeEmail         String    @map("employee_email")
  startDate             String    @map("start_date")
  endDate               String    @map("end_date")
  isDeleted             Boolean   @default(false) @map("is_deleted")
  cancelledAt           DateTime? @map("cancelled_at")
  cancelledById         Int?      @map("cancelled_by")
  cancelledBy           User?     @relation("LeaveRequestCancelledBy", fields: [cancelledById], references: [id])
  editedAt              DateTime? @map("edited_at")
  editedById            Int?      @map("edited_by")
  editedBy              User?     @relation("LeaveRequestEditedBy", fields: [editedById], references: [id])
  acceptedAt            DateTime? @map("accepted_at")
  acceptedById          Int?      @map("accepted_by")
  acceptedBy            User?     @relation("LeaveRequestAcceptedBy", fields: [acceptedById], references: [id])
  description           String?
  status                String    @default("pending")
  googleCalendarEventId String?   @map("google_calendar_event_id")
  createdAt             DateTime  @default(now()) @map("created_at")

  @@map("leave_requests")
}
